# Copy to .env (or set in your host's dashboard). Never commit real keys.

# Enables grounded AI tagging via Claude tool-use. Without it the app still
# works using the local keyword fallback engine.
ANTHROPIC_API_KEY=

# Optional overrides.
ANTHROPIC_MODEL=claude-haiku-4-5
AI_MAX_TOOL_TURNS=3
PORT=5000

# --- Cost controls (see README "Costs") ---
# Max AI analyses per UTC day; over this the app degrades to the free local
# engine instead of calling the API. The hard backstop is the monthly spend
# limit you set in the Anthropic console.
AI_DAILY_LIMIT=50
# Max characters of the case description sent to the API (bounds input tokens).
MAX_CASE_CHARS=6000
